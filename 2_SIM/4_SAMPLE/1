`timescale 1ns/1ps

module pipeline(
input clk, 
input rst_n,
input [9:0] a,
input [9:0] b,
input [9:0] c,
output [11:0] Q
);
reg [9:0] q0;
reg [10:0] q1;
reg [11:0] q2;

always @(posedge clk) begin
	if(!rst_n) begin

	q0<=0;
	q1<=0;
	q2<=0;
        end

	else begin
	q0<=c;
	q1<= a+b;
	q2<=q0+q1;	

	end

end

assign Q = q2;



endmodule
