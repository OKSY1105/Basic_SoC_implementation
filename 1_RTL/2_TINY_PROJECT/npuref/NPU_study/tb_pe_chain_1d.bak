//2d-demenstion (systolic array) ?? ?? 1-dimension ?? ??? ??)

`timescale 1ns/1ps

module tb_pe_chain_1d;

  localparam DATA_W   = 8;
  localparam ACC_W    = 16;  // 2*DATA_W
  localparam NUM_PE   = 4;
  localparam SIM_TIME = 3000;  // ns ??

  //==========================================================
  // DUT ??
  //==========================================================
  reg                       clk;
  reg                       rst_n;
  reg                       clr;
  reg                       en;
  reg  [DATA_W-1:0]         in_data;
  wire [DATA_W-1:0]         out_data;
  
  reg  [DATA_W-1:0]         weight_0;
  reg  [DATA_W-1:0]         weight_1;
  reg  [DATA_W-1:0]         weight_2;
  reg  [DATA_W-1:0]         weight_3;

  wire [ACC_W-1:0]          pe_mul_0;
  wire [ACC_W-1:0]          pe_mul_1;
  wire [ACC_W-1:0]          pe_mul_2;
  wire [ACC_W-1:0]          pe_mul_3;
  
  wire [ACC_W-1:0]          pe_acc_sum_0;
  wire [ACC_W-1:0]          pe_acc_sum_1;
  wire [ACC_W-1:0]          pe_acc_sum_2;
  wire [ACC_W-1:0]          pe_acc_sum_3;

  pe_chain_1d #(
    .DATA_W (DATA_W),
    .ACC_W  (ACC_W),
    .NUM_PE (NUM_PE)
  ) dut (
    .clk         (clk),
    .rst_n       (rst_n),
    .clr         (clr),
    .en          (en),
    .in_data     (in_data),
    .out_data    (out_data),
    .weight_0    (weight_0),
    .weight_1    (weight_1),
    .weight_2    (weight_2),
    .weight_3    (weight_3),
    .pe_mul_0    (pe_mul_0),
    .pe_mul_1    (pe_mul_1),
    .pe_mul_2    (pe_mul_2),
    .pe_mul_3    (pe_mul_3),
    .pe_acc_sum_0(pe_acc_sum_0),
    .pe_acc_sum_1(pe_acc_sum_1),
    .pe_acc_sum_2(pe_acc_sum_2),
    .pe_acc_sum_3(pe_acc_sum_3)
  );

  //==========================================================
  // Clock / Reset
  //==========================================================
  initial begin
    clk = 1'b0;
    forever #5 clk = ~clk;  // 100MHz
  end

  initial begin
    rst_n   = 1'b0;
    clr     = 1'b0;
    en      = 1'b0;
    in_data = 0;

    // weight ??? (?: 1,2,3,4,...)
    weight_0 = 1;
    weight_1 = 2;
    weight_2 = 3;
    weight_3 = 4;

    #30;
    rst_n = 1'b1;
  end

  //==========================================================
  // Reference Model
  //==========================================================
  // ??? ????? ??
  reg [DATA_W-1:0] ref_data_pipe_0;
  reg [DATA_W-1:0] ref_data_pipe_1;
  reg [DATA_W-1:0] ref_data_pipe_2;
  reg [DATA_W-1:0] ref_data_pipe_3;
  
  // ? PE? ???
  reg [ACC_W-1:0]  ref_sum_0;
  reg [ACC_W-1:0]  ref_sum_1;
  reg [ACC_W-1:0]  ref_sum_2;
  reg [ACC_W-1:0]  ref_sum_3;

  // ref ??: DUT? data_pipe / ?? ??? ??? ???? ??
  always @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      ref_data_pipe_0 <= 0;
      ref_data_pipe_1 <= 0;
      ref_data_pipe_2 <= 0;
      ref_data_pipe_3 <= 0;
    end else begin
      ref_data_pipe_0 <= in_data;
      ref_data_pipe_1 <= ref_data_pipe_0;
      ref_data_pipe_2 <= ref_data_pipe_1;
      ref_data_pipe_3 <= ref_data_pipe_2;
    end
  end

  always @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      ref_sum_0 <= 0;
      ref_sum_1 <= 0;
      ref_sum_2 <= 0;
      ref_sum_3 <= 0;
    end else begin
      if (clr) begin
        ref_sum_0 <= 0;
        ref_sum_1 <= 0;
        ref_sum_2 <= 0;
        ref_sum_3 <= 0;
      end else if (en) begin
        ref_sum_0 <= ref_sum_0 + (ref_data_pipe_0 * weight_0);
        ref_sum_1 <= ref_sum_1 + (ref_data_pipe_1 * weight_1);
        ref_sum_2 <= ref_sum_2 + (ref_data_pipe_2 * weight_2);
        ref_sum_3 <= ref_sum_3 + (ref_data_pipe_3 * weight_3);
      end
      // en=0?? ??
    end
  end

  //==========================================================
  // Checker (Watchpoint)
  //==========================================================
  integer cycles_checked;
  integer err_mul_cnt;
  integer err_acc_cnt;

  // ?? mul ?
  wire [ACC_W-1:0] ref_mul_0 = ref_data_pipe_0 * weight_0;
  wire [ACC_W-1:0] ref_mul_1 = ref_data_pipe_1 * weight_1;
  wire [ACC_W-1:0] ref_mul_2 = ref_data_pipe_2 * weight_2;
  wire [ACC_W-1:0] ref_mul_3 = ref_data_pipe_3 * weight_3;

  always @(posedge clk) begin
    if (!rst_n) begin
      cycles_checked <= 0;
      err_mul_cnt    <= 0;
      err_acc_cnt    <= 0;
    end else begin
      cycles_checked <= cycles_checked + 1;

      // PE0 ??
      if (pe_mul_0 !== ref_mul_0) begin
        err_mul_cnt <= err_mul_cnt + 1;
        $display("ERROR! [PE0] WP1 MUL mismatch: dut=%0d, ref=%0d, data=%0d, w=%0d, time=%0d ns",
                 pe_mul_0, ref_mul_0, ref_data_pipe_0, weight_0, $time);
      end else begin
        $display("PASS!  [PE0] WP1 MUL match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_mul_0, ref_mul_0, $time);
      end

      if (pe_acc_sum_0 !== ref_sum_0) begin
        err_acc_cnt <= err_acc_cnt + 1;
        $display("ERROR! [PE0] WP2 ACC_SUM mismatch: dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_0, ref_sum_0, $time);
      end else begin
        $display("PASS!  [PE0] WP2 ACC_SUM match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_0, ref_sum_0, $time);
      end

      // PE1 ??
      if (pe_mul_1 !== ref_mul_1) begin
        err_mul_cnt <= err_mul_cnt + 1;
        $display("ERROR! [PE1] WP1 MUL mismatch: dut=%0d, ref=%0d, data=%0d, w=%0d, time=%0d ns",
                 pe_mul_1, ref_mul_1, ref_data_pipe_1, weight_1, $time);
      end else begin
        $display("PASS!  [PE1] WP1 MUL match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_mul_1, ref_mul_1, $time);
      end

      if (pe_acc_sum_1 !== ref_sum_1) begin
        err_acc_cnt <= err_acc_cnt + 1;
        $display("ERROR! [PE1] WP2 ACC_SUM mismatch: dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_1, ref_sum_1, $time);
      end else begin
        $display("PASS!  [PE1] WP2 ACC_SUM match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_1, ref_sum_1, $time);
      end

      // PE2 ??
      if (pe_mul_2 !== ref_mul_2) begin
        err_mul_cnt <= err_mul_cnt + 1;
        $display("ERROR! [PE2] WP1 MUL mismatch: dut=%0d, ref=%0d, data=%0d, w=%0d, time=%0d ns",
                 pe_mul_2, ref_mul_2, ref_data_pipe_2, weight_2, $time);
      end else begin
        $display("PASS!  [PE2] WP1 MUL match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_mul_2, ref_mul_2, $time);
      end

      if (pe_acc_sum_2 !== ref_sum_2) begin
        err_acc_cnt <= err_acc_cnt + 1;
        $display("ERROR! [PE2] WP2 ACC_SUM mismatch: dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_2, ref_sum_2, $time);
      end else begin
        $display("PASS!  [PE2] WP2 ACC_SUM match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_2, ref_sum_2, $time);
      end

      // PE3 ??
      if (pe_mul_3 !== ref_mul_3) begin
        err_mul_cnt <= err_mul_cnt + 1;
        $display("ERROR! [PE3] WP1 MUL mismatch: dut=%0d, ref=%0d, data=%0d, w=%0d, time=%0d ns",
                 pe_mul_3, ref_mul_3, ref_data_pipe_3, weight_3, $time);
      end else begin
        $display("PASS!  [PE3] WP1 MUL match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_mul_3, ref_mul_3, $time);
      end

      if (pe_acc_sum_3 !== ref_sum_3) begin
        err_acc_cnt <= err_acc_cnt + 1;
        $display("ERROR! [PE3] WP2 ACC_SUM mismatch: dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_3, ref_sum_3, $time);
      end else begin
        $display("PASS!  [PE3] WP2 ACC_SUM match   : dut=%0d, ref=%0d, time=%0d ns",
                 pe_acc_sum_3, ref_sum_3, $time);
      end
    end
  end

  //==========================================================
  // Time-based Random Stimulus
  //==========================================================
  initial begin
    @(posedge rst_n);
    @(posedge clk);

    $display("[TB] 1D PE Chain Time-based Random Stress START, duration = %0d ns", SIM_TIME);

    fork
      // ?? ?? ?? ???
      begin
        forever begin
          // ?? ?? ???
          in_data = $random & ((1<<DATA_W)-1);

          // en ??
          en = $random & 1;

          // clr? ?? ??? ?? (5%)
          if (($random % 100) < 5) begin
            clr = 1'b1;
          end else begin
            clr = 1'b0;
          end

          @(posedge clk);
        end
      end

      // ?? ?? ???
      begin
        #SIM_TIME;
        disable fork;
      end
    join

    // Summary
    $display("==================================================");
    $display("[TB] 1D PE Chain Simulation Summary");
    $display("  Simulation time    : %0d ns", SIM_TIME);
    $display("  Cycles checked     : %0d",    cycles_checked);
    $display("  MUL mismatches     : %0d",    err_mul_cnt);
    $display("  ACC_SUM mismatches : %0d",    err_acc_cnt);
    if (err_mul_cnt == 0 && err_acc_cnt == 0) begin
      $display("  RESULT             : PASS");
    end else begin
      $display("  RESULT             : FAIL");
    end
    $display("==================================================");

    $finish;
  end

endmodule
