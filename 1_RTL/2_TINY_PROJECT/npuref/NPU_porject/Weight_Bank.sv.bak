`include "include.v"
module Weight_Bank #(
а а parameter dataWidth = 8
)(
а а input clk,
а а input [31:0] layer_idx,
а а input [31:0] neuron_group,
а а input [31:0] w_addr,
а аа
а а output reg [4*dataWidth-1:0] w_out_packed
);

а а wire [dataWidth-1:0] w_l1 [`numNeuronLayer1-1:0];
а а wire [dataWidth-1:0] w_l2 [`numNeuronLayer2-1:0];
а а wire [dataWidth-1:0] w_l3 [`numNeuronLayer3-1:0];

а а genvar i;
а аа
    generate
        for(i=0; i<`numNeuronLayer1; i=i+1) begin : L1_MEM
            Weight_Memory #(.numWeight(`numWeightLayer1), .dataWidth(dataWidth), .weightFile($sformatf("w_1_%0d.mif", i))) 
            wm (.clk(clk), .wen(1'b0), .ren(1'b1), .wadd(10'd0), .win({dataWidth{1'b0}}), .radd(w_addr[9:0]), .wout(w_l1[i]));
        end
        for(i=0; i<`numNeuronLayer2; i=i+1) begin : L2_MEM
            Weight_Memory #(.numWeight(`numWeightLayer2), .dataWidth(dataWidth), .weightFile($sformatf("w_2_%0d.mif", i))) 
            wm (.clk(clk), .wen(1'b0), .ren(1'b1), .wadd(10'd0), .win({dataWidth{1'b0}}), .radd(w_addr[9:0]), .wout(w_l2[i]));
        end
        for(i=0; i<`numNeuronLayer3; i=i+1) begin : L3_MEM
            Weight_Memory #(.numWeight(`numWeightLayer3), .dataWidth(dataWidth), .weightFile($sformatf("w_3_%0d.mif", i))) 
            wm (.clk(clk), .wen(1'b0), .ren(1'b1), .wadd(10'd0), .win({dataWidth{1'b0}}), .radd(w_addr[9:0]), .wout(w_l3[i]));
        end
    endgenerate
а аа
а а reg [dataWidth-1:0] sel_w [0:3];
а а reg [dataWidth-1:0] raw_w;а

а а localparam L1 = 'd1;
а а localparam L2 = 'd2;
а а localparam L3 = 'd3;

а а integer k;
а аа
а а always @(*) begin
а аа
а а а а // weight ??
а а а а for (k = 0; k < 4; k = k + 1) begin
а а а а а а int idx;
а а а а а а //idx = neuron_group*4 + k;
а а а а а а idx = (neuron_group << 2) + k;а а// multiply by 4 ? HW-friendly shift
а а а а а а raw_w = '0;
а аа
а а а а а а // layer ??
а а а а а а case (layer_idx)
а а а а а а а а L1: if (idx < `numNeuronLayer1) raw_w = w_l1[idx];
а а а а а а а а L2: if (idx < `numNeuronLayer2) raw_w = w_l2[idx];
а а а а а а а а L3: if (idx < `numNeuronLayer3) raw_w = w_l3[idx];
а а а а а а а а default: raw_w = '0;
а а а а а а endcase

а а а а а а sel_w[k] = raw_w;
а а а а end
а аа
а а а а // weight 4?? ??
а а а а w_out_packed = {sel_w[3], sel_w[2], sel_w[1], sel_w[0]};
а а end

endmodule