module Global_Buffer #(
    parameter dataWidth = 8
)(
    input clk,
    input wen,
    input [31:0] w_addr, 
    input [dataWidth-1:0] w_data,
    
    // 4 Read Ports for Systolic Array
    input [31:0] r_addr_0, 
    input [31:0] r_addr_1, 
    input [31:0] r_addr_2, 
    input [31:0] r_addr_3, 
    
    output [dataWidth-1:0] r_data_0,
    output [dataWidth-1:0] r_data_1,
    output [dataWidth-1:0] r_data_2,
    output [dataWidth-1:0] r_data_3
);

    reg [dataWidth-1:0] mem [255:0];

    always @(posedge clk) begin
        if (wen) begin
            mem[w_addr] <= w_data;
        end
    end

    assign r_data_0 = mem[r_addr_0];
    assign r_data_1 = mem[r_addr_1];
    assign r_data_2 = mem[r_addr_2];
    assign r_data_3 = mem[r_addr_3];

endmodule